# =============================================================================
# ResearchFlow — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- AWS ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_SESSION_TOKEN=          # Only needed for temporary credentials
SAGEMAKER_ROLE_ARN=arn:aws:iam::123456789012:role/YourSageMakerRole

# --- AWS Bedrock ---
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
# BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0  # If using Bedrock embeddings instead of Sentence Transformers

# --- Pinecone ---
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=researchflow
PINECONE_ENVIRONMENT=us-east-1     # Serverless region

# --- LangSmith (Observability) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=researchflow

# --- Application Settings ---
MAX_REFINEMENT_ITERATIONS=3
HITL_CONFIDENCE_THRESHOLD=0.6
SLIDING_WINDOW_SIZE=20
